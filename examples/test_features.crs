// Helper functions for test functions

func add(a, b) {
    return a + b;
}

func greet(name) {
    println("Hello,", name);
    return "Greeted";
}

func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func increment(vals) {
    vals.value += 1;
}

func getValue(vals) {
    return vals.value;
}

// TEST 1: Basic Printing
func test_printing() {
    println("=== TEST 1: Basic Printing ===");
    println("Hello, World!");
    println("Number:", 42);
    println("Float:", 3.14);
    println("Bool:", true);
    println("Done");
}

// TEST 2: Variables and Basic Types
func test_variables() {
    println("=== TEST 2: Variables and Types ===");
    
    let x = 10;
    println("Integer:", x);
    
    let y = 3.14;
    println("Float:", y);
    
    let b = true;
    println("Bool:", b);
    
    let s = "Hello";
    println("String:", s);
    
    let n = null;
    println("Null:", n);
}

// TEST 3: Arithmetic Operations
func test_arithmetic() {
    println("=== TEST 3: Arithmetic Operations ===");
    
    println("Add:", 5 + 3);
    println("Sub:", 5 - 3);
    println("Mul:", 5 * 3);
    println("Div:", 10.0 / 3);
    println("Mod:", 10 / 3);
    println("Neg:", -5);
}

// TEST 4: Comparison Operations
func test_comparison() {
    println("=== TEST 4: Comparison Operations ===");
    
    println("5 == 5:", 5 == 5);
    println("5 != 3:", 5 != 3);
    println("5 > 3:", 5 > 3);
    println("5 < 3:", 5 < 3);
    println("5 >= 5:", 5 >= 5);
    println("5 <= 3:", 5 <= 3);
}

// TEST 5: Logical Operations
func test_logical() {
    println("=== TEST 5: Logical Operations ===");
    
    println("true and true:", true and true);
    println("true and false:", true and false);
    println("true or false:", true or false);
    println("false or false:", false or false);
    println("not true:", not true);
    println("not false:", not false);
}

// TEST 6: If-Else Statements
func test_if_else() {
    println("=== TEST 6: If-Else Statements ===");
    
    let x = 10;
    if (x > 5) {
        println("x > 5");
    } else {
        println("x <= 5");
    }
    
    if (x == 10) {
        println("x equals 10");
    } else if (x > 10) {
        println("x > 10");
    } else {
        println("x < 10");
    }
}

// TEST 7: While Loop
func test_while_loop() {
    println("=== TEST 7: While Loop ===");
    
    let i = 0;
    while (i < 3) {
        println("Loop iteration:", i);
        i = i + 1;
    }
}

// TEST 8: For Loop
func test_for_loop() {
    println("=== TEST 8: For Loop ===");
    
    for (let i = 0; i < 3; i = i + 1) {
        println("For loop i:", i);
    }
}

// TEST 9: Arrays
func test_arrays() {
    println("=== TEST 9: Arrays ===");
    
    let arr = [1, 2, 3, 4, 5];
    println("Array:", arr);
    println("Access arr[0]:", arr[0]);
    println("Access arr[2]:", arr[2]);
    
    arr[1] = 20;
    println("After arr[1] = 20:", arr[1]);
    
    push(arr, 6);
    println("After push(6), length:", len(arr));
}

// TEST 10: Tables
func test_tables() {
    println("=== TEST 10: Tables ===");
    
    let obj = {
        name: "Test",
        age: 25,
        city: "NYC"
    };
    
    println("Table:", obj);
    println("obj.name:", obj.name);
    println("obj.age:", obj.age);
    
    obj.age = 26;
    println("After obj.age = 26:", obj.age);
}

